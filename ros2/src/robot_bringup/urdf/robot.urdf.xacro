<?xml version="1.0"?>
<!--
  Outdoor ground robot built from hoverboard parts.

  Form (docs/handoff.md decision 1): a four-point STATIC platform — two driven
  hub wheels on one axle, two casters. Not self-balancing. Nothing here models a
  balancing robot's inverted pendulum, because we deliberately do not have one.

  Every dimension marked TODO is a placeholder: the chassis is roadmap step 3 and
  does not exist yet. What matters for localization today is the SENSOR FRAMES —
  robot_localization and navsat_transform read the IMU, magnetometer and GPS
  poses out of this tree, so a lie here becomes a constant error in the estimate
  that no amount of filter tuning will remove.

  Frames follow REP-103: x forward, y left, z up.
-->
<robot name="hoverbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==== Geometry ========================================================= -->
  <!-- 6.5" hoverboard hub wheel: 165 mm diameter. This one is real. -->
  <xacro:property name="wheel_radius" value="0.0825"/>
  <xacro:property name="wheel_width" value="0.06"/>
  <!-- TODO: measure centre-to-centre on the real chassis. Must match
       wheel_separation in config/hoverboard_bridge.yaml — if these two disagree,
       the URDF and the odometry describe different robots. -->
  <xacro:property name="wheel_separation" value="0.5"/>

  <!-- TODO: all placeholders until the chassis is cut. -->
  <xacro:property name="base_length" value="0.60"/>
  <xacro:property name="base_width" value="0.40"/>
  <xacro:property name="base_height" value="0.08"/>
  <!-- Deck sits just above the axle. -->
  <xacro:property name="base_z" value="${wheel_radius + 0.02}"/>

  <xacro:property name="caster_radius" value="0.0625"/>  <!-- 125 mm caster -->
  <xacro:property name="caster_x" value="0.22"/>          <!-- forward of the axle -->
  <xacro:property name="caster_y" value="0.15"/>

  <!-- Magnetometer mast. Decision 4: >30 cm above the deck, away from the motor
       cables, or the hub motors' field swamps the earth's. -->
  <xacro:property name="mast_height" value="0.45"/>

  <xacro:property name="wheel_mass" value="2.5"/>
  <xacro:property name="base_mass" value="12.0"/>  <!-- TODO: weigh it -->

  <material name="grey"><color rgba="0.4 0.4 0.4 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material>

  <!-- ==== Macros =========================================================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" iyy="${m*(x*x+z*z)/12.0}"
               izz="${m*(x*x+y*y)/12.0}" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12.0}" iyy="${m*(3*r*r+l*l)/12.0}"
               izz="${m*r*r/2.0}" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- Driven hub wheel. Rotates about its own y axis, hence the rpy roll. -->
  <xacro:macro name="drive_wheel" params="prefix reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>

    <!-- Joint names must match what hoverboard_bridge publishes on
         /joint_states, or robot_state_publisher silently animates nothing. -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${reflect * wheel_separation / 2.0} ${wheel_radius}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Casters are modelled as fixed spheres: they carry weight and set the
       platform's height, but they steer passively and we never command them, so
       giving them joints would only add unobservable state. -->
  <xacro:macro name="caster" params="prefix x y">
    <link name="${prefix}_caster">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster"/>
      <origin xyz="${x} ${y} ${caster_radius}"/>
    </joint>
  </xacro:macro>

  <!-- ==== Links ============================================================ -->
  <!-- base_link sits on the ground, centred on the drive axle. Ground level
       keeps two_d_mode honest and makes the Nav2 footprint trivial. -->
  <link name="base_link"/>

  <link name="chassis">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>
  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="${caster_x/2.0} 0 ${base_z + base_height/2.0}"/>
  </joint>

  <xacro:drive_wheel prefix="left" reflect="1"/>
  <xacro:drive_wheel prefix="right" reflect="-1"/>
  <xacro:caster prefix="front_left" x="${caster_x}" y="${caster_y}"/>
  <xacro:caster prefix="front_right" x="${caster_x}" y="${-caster_y}"/>

  <!-- ==== Sensor frames ==================================================== -->
  <!-- IMU. Ideally at the centre of rotation, i.e. the middle of the drive axle:
       the further out it sits, the more centripetal acceleration it reads during
       turns and mistakes for translation. -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- TODO: measure once mounted. rpy must describe the chip's real
         orientation — REP-103 wants x forward, y left, z up. -->
    <origin xyz="0 0 ${base_z + base_height}" rpy="0 0 0"/>
  </joint>

  <!-- Magnetometer on the mast, far from the hub motors (decision 4).
       NOT PURCHASED YET (QMC5883L, ~100 TL) — the frame is here so the mount
       height is a decision on paper before it is a decision in aluminium. -->
  <link name="mast_link">
    <visual>
      <origin xyz="0 0 ${mast_height/2.0}"/>
      <geometry><cylinder radius="0.012" length="${mast_height}"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <origin xyz="${-0.15} 0 ${base_z + base_height}"/>
  </joint>

  <link name="mag_link"/>
  <joint name="mag_joint" type="fixed">
    <parent link="mast_link"/>
    <child link="mag_link"/>
    <origin xyz="0 0 ${mast_height}" rpy="0 0 0"/>
  </joint>

  <!-- GPS antenna. navsat_transform uses this frame's offset from base_link, so
       a sloppy number here is a constant position bias — small next to the
       NEO-6M's ~5 m, but free to get right. Keep the antenna >20 cm from the Pi:
       USB3/HDMI noise sits right in the GPS band (docs/wiring-map.md). -->
  <link name="gps_link"/>
  <joint name="gps_joint" type="fixed">
    <parent link="mast_link"/>
    <child link="gps_link"/>
    <origin xyz="0 0 ${mast_height - 0.08}"/>
  </joint>

  <!-- Pi Camera V2, forward and slightly down for ground segmentation
       (roadmap step 7). -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${base_length/2.0} 0 ${base_z + base_height + 0.05}" rpy="0 0.35 0"/>
  </joint>

  <!-- REP-103 optical frame: z forward, x right, y down. image_pipeline and the
       Nav2 costmap plugins assume this exists; hand-rolling it later is a
       classic afternoon lost to an upside-down point cloud. -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

</robot>
